# ===== NexusAI — API Keys =====
# Each AI provider powers a subset of the 11 modes.
# Get your keys from the links below.

# Google Gemini (free tier available)
# https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI
# https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Groq (free tier — uses Llama / Mixtral)
# https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Auth settings
AUTH_JWT_SECRET=replace_with_a_long_random_secret
AUTH_JWT_EXPIRES_IN=7d

# Firebase Admin SDK settings
# Create a Service Account Key in Firebase Console, then stringify the JSON
FIREBASE_SERVICE_ACCOUNT_KEY='{"type": "service_account", "project_id": "nexus-ai", "private_key": "-----BEGIN PRIVATE...", "client_email": "..."}'
